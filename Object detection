from ultralytics import YOLO

# Load a pre-trained heavyweight model
model = YOLO('yolov8x.pt')  # yolov8n/s/m/l/x - x is the largest

# Ensure 'val' key in data.yaml and correct path to validation images
model.train(data='/content/drive/MyDrive/currency(yolo)/data.yaml',
            epochs=50,
            imgsz=640,
            batch=2,
            workers=1,
            rect=True)  # uses rectangular training, helps skip bad images
metrics = model.val()

